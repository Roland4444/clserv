server {
    listen 443 ssl;
    listen [::]:443 ssl; # Для поддержки IPv6

    server_name romach.space www.romach.soace;

    ssl_certificate /etc/letsencrypt/live/romach.space/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/romach.space/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    client_max_body_size 50M;  # или нужный вам размер

#https://romach.space/chat
    location / {
        proxy_pass http://127.0.0.1:11111;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }


}

server {
    listen 80;
    listen [::]:80;
    server_name romach.space www.romach.space;

    return 301 https://$host$request_uri;
}
